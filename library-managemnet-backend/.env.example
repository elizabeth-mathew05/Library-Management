PORT=5000
NODE_ENV=development
# Use a hosted MongoDB connection string in production (for Render, set this in the dashboard)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/library_management?retryWrites=true&w=majority
# Optional fallback DB name if URI path omits database name
MONGO_DB_NAME=library_management
# Mongo connection startup retries (useful for transient Atlas selection errors)
MONGO_CONNECT_RETRIES=5
MONGO_CONNECT_RETRY_DELAY_MS=5000
JWT_SECRET=replace_with_a_secure_secret
FRONTEND_URL=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
STRIPE_SECRET_KEY=sk_test_replace_me
LATE_FEE_PER_DAY=2
MAX_BORROW_LIMIT=3
DEFAULT_BORROW_DAYS=14
