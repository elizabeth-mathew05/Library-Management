# ============ GENERAL =================
NODE_ENV=development
PORT=5000

# ============ DATABASE =================
# Use a hosted MongoDB connection string in production (for Render, set this in the dashboard)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/library_management?retryWrites=true&w=majority
# Optional fallback DB name if URI path omits database name
MONGO_DB_NAME=library_management

# ============ JWT AUTHENTICATION =================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ============ BORROWING SYSTEM =================
# Default borrowing period in days
DEFAULT_BORROW_DAYS=14

# Maximum number of books a user can borrow simultaneously
MAX_BORROW_LIMIT=3

# Late fee per day (in dollars)
LATE_FEE_PER_DAY=2

# Automatic overdue reminder schedule (server local time)
OVERDUE_REMINDER_HOUR=9
OVERDUE_REMINDER_MINUTE=0
OVERDUE_REMINDER_CHECK_MS=60000

# ============ EMAIL SERVICE (SMTP) =================
# Gmail: smtp.gmail.com (port 587)
# Outlook: smtp-mail.outlook.com (port 587)
# SendGrid: smtp.sendgrid.net (port 587)
# Note: For Gmail, use an App Password, not your regular password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ============ FRONTEND (Optional) =================
# Set if frontend is on different port during development
REACT_APP_API_URL=http://localhost:5000/api

# ============ CLOUD STORAGE (Optional) =================
# For book cover images
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
